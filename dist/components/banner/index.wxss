.dov-banner {
  width: 100%;
  overflow: hidden;
}

.dov-banner__swiper {
  width: 100%;
}

.dov-banner__item {
  position: relative;
  width: 100%;
  height: 100%;
}

.dov-banner__image {
  width: 100%;
  height: 100%;
  display: block;
}

.dov-banner__content {
  position: absolute;
  left: 0;
  right: 0;
  padding: 12px 16px;
  background: linear-gradient(to bottom, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.6));
  color: var(--dov-banner__text-color, #fff);
}

.dov-banner__title {
  font-size: var(--dov-banner__title-font-size, 16px);
  font-weight: var(--dov-banner__title-font-weight, 500);
  line-height: 22px;
  margin-bottom: 4px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.dov-banner__desc {
  font-size: var(--dov-banner__desc-font-size, 12px);
  line-height: 18px;
  opacity: 0.9;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
