.progress-card {
  margin: 20rpx;
}

/* ========== 顶部渐变卡片 ========== */
.progress-card__summary {
  background: linear-gradient(135deg, #d4a574 0%, #c89961 50%, #b8864e 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.4);
  position: relative;
  /* 木纹材质效果 */
  background-image: 
    linear-gradient(135deg, #d4a574 0%, #c89961 50%, #b8864e 100%),
    repeating-linear-gradient(
      90deg,
      rgba(160, 120, 80, 0.03) 0px,
      rgba(160, 120, 80, 0.03) 2px,
      transparent 2px,
      transparent 4px
    ),
    repeating-linear-gradient(
      0deg,
      rgba(140, 100, 60, 0.05) 0px,
      rgba(140, 100, 60, 0.05) 1px,
      transparent 1px,
      transparent 3px
    );
}

/* 编辑/保存按钮 */
.progress-card__edit-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.progress-card__edit-btn:active {
  background: rgba(255, 255, 255, 0.35);
  transform: scale(0.95);
}

.progress-card__edit-icon {
  font-size: 32rpx;
  color: #ffffff;
}

.progress-card__save-icon {
  font-size: 36rpx;
  color: #ffffff;
  font-weight: bold;
}

.progress-card__info {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.progress-card__info-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.progress-card__info-item {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.progress-card__label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.progress-card__value {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  text-shadow: 0 1rpx 3rpx rgba(0, 0, 0, 0.15);
}

/* 输入框容器 */
.progress-card__input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.progress-card__input {
  font-size: 28rpx;
  font-weight: 500;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  padding: 8rpx 12rpx;
  min-height: 56rpx;
  box-sizing: border-box;
  flex: 1;
  text-shadow: 0 1rpx 2rpx rgba(0, 0, 0, 0.1);
}

.progress-card__input--has-suffix {
  padding-right: 60rpx;
}

.progress-card__suffix {
  position: absolute;
  right: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.7);
  pointer-events: none;
}

.progress-card__input::placeholder {
  color: rgba(255, 255, 255, 0.5);
}
